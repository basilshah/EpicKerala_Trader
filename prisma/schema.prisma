generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  
  @@index([slug])
  @@index([parentId, name])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed password
  name      String
  role      String   @default("admin") // admin, superadmin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seller {
  id              String   @id @default(cuid())
  companyName     String
  slug            String   @unique
  description     String?
  type            String   // Manufacturer, Merchant Exporter
  logoUrl         String?
  
  // Authentication
  password        String   // Hashed password
  
  // Contact
  email           String   @unique
  phone           String?
  website         String?
  
  // Location
  address         String?
  city            String?
  state           String?
  country         String   @default("India")
  pincode         String?
  
  // Trust Markers
  establishedYear Int?
  isVerified      Boolean  @default(false)
  certifications  String?  // JSON string or comma separated
  certificationFiles String? // JSON array of file URLs
  profileVideoUrl String?  // YouTube, Vimeo, or other video URL
  catalogs        String?  // JSON array of catalog files (PDF/images)
  
  // OEM/Private Label
  offersOEM       Boolean  @default(false)
  
  // Contact Person
  contactPersonName        String?
  contactPersonDesignation String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  products        Product[]
  
  @@index([isVerified])
}

model Importer {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  password        String   // Hashed password
  
  // Subscription
  subscriptionTier String  @default("FREE") // FREE, PREMIUM
  
  // Company Info (optional)
  companyName     String?
  country         String?
  phone           String?
  
  // Meta
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  rfqs            RFQ[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  
  // Relations
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  // Specs
  hsCode      String?
  moq         String?  // Minimum Order Quantity (e.g. "500 kg")
  origin      String   @default("India")
  shelfLife   String?
  
  // Media
  images      String?  // JSON array of URLs
  catalogs    String?  // JSON array of catalog files (PDF/images)
  certificationFiles String? // JSON array of certification files (PDF/images)
  
  // Admin Verification
  verificationStatus String @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason    String? // Reason if rejected
  verifiedAt         DateTime?
  
  // Meta
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  rfqs        RFQ[]
  
  @@index([isPublic, verificationStatus])
  @@index([categoryId])
}

model RFQ {
  id              String   @id @default(cuid())
  
  // Buyer Info
  buyerName       String
  buyerCompany    String?
  buyerEmail      String
  buyerCountry    String?
  
  // Request Details
  quantity        String?
  message         String
  
  // Relations
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  importerId      String?
  importer        Importer? @relation(fields: [importerId], references: [id])
  
  status          String   @default("PENDING") // PENDING, SENT, REPLIED
  createdAt       DateTime @default(now())
}

model UploadedFile {
  id         String   @id @default(cuid())
  type       String   // image | pdf
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())
  userId     String

  @@index([userId, uploadedAt])
  @@index([type])
}
